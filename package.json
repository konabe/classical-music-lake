{
  "name": "classical-music-lake",
  "version": "1.6.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "npm run test:backend",
    "test:frontend": "vitest run --exclude 'backend/**'",
    "test:backend": "cd backend && npm test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts",
    "generate-mock-data": "node scripts/generate-mock-data.mjs",
    "lint": "eslint . && stylelint \"app/**/*.vue\"",
    "lint:fix": "eslint . --fix && stylelint \"app/**/*.vue\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node -e \"if (process.env.CI !== 'true') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "nuxt": "^4.4.2",
    "vue": "^3.5.31",
    "vue-router": "^4.0.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "h3-next": "npm:h3@2.0.1-rc.16"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "stylelint --fix"
    ],
    "*.md": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/storybook": "^9.0.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.4",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "playwright": "^1.59.1",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
