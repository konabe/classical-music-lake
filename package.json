{
  "name": "classical-music-lake",
  "version": "1.10.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "pnpm run test:backend",
    "test:frontend": "vitest run --exclude 'backend/**'",
    "test:frontend:ci": "vitest run --exclude 'backend/**' --reporter=default --reporter=junit --outputFile.junit=test-report.junit.xml",
    "test:backend": "pnpm -C backend test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts",
    "generate-mock-data": "node scripts/generate-mock-data.mjs",
    "lint": "eslint . && stylelint \"app/**/*.vue\"",
    "lint:fix": "eslint . --fix && stylelint \"app/**/*.vue\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node -e \"if (process.env.CI !== 'true') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "stryker": "stryker run",
    "stryker:backend": "pnpm -C backend run stryker"
  },
  "dependencies": {
    "nuxt": "^4.4.2",
    "vue": "^3.5.31",
    "vue-router": "^4.0.0",
    "vuedraggable": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "h3-next": "npm:h3@2.0.1-rc.16",
      "undici": ">=6.24.0",
      "fast-xml-parser": "5.5.6"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver"
    ],
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-v2wj-q39q-566r",
        "GHSA-p9ff-h696-f583"
      ]
    }
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "stylelint --fix"
    ],
    "*.md": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/storybook": "^9.0.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.4",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "playwright": "^1.59.1",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  }
}
