    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/typescript-build": "latest",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0"
  }
