{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Nuxt Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "NUXT_PUBLIC_API_BASE_URL": ""
      }
    }
  ]
}
