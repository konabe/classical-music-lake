# Nuxt フロントエンド ローカル開発用環境変数

# API Gateway のベース URL (末尾スラッシュなし)
# 例: https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/prod
NUXT_PUBLIC_API_BASE_URL=

# Cognito Hosted UI のドメイン (プロトコル・パス無し)
# 例: classical-music-lake-dev.auth.ap-northeast-1.amazoncognito.com
NUXT_PUBLIC_COGNITO_DOMAIN=

# Cognito User Pool の App Client ID
# CDK 出力 `CognitoClientId` の値を使用する
NUXT_PUBLIC_COGNITO_CLIENT_ID=
