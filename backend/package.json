{
  "name": "classical-music-lake-backend",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:setup": "node scripts/setup-test-db.mjs",
    "db:seed": "node scripts/seed-test-db.mjs",
    "db:reset": "npm run db:setup && npm run db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1006.0",
    "@aws-sdk/lib-dynamodb": "^3.1009.0",
    "@middy/core": "^7.1.4",
    "@middy/http-cors": "^7.1.3",
    "@middy/http-error-handler": "^7.1.4",
    "@middy/http-response-serializer": "^7.1.3",
    "http-errors": "^2.0.1",
    "http-status-codes": "^2.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/http-errors": "^2.0.5",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
