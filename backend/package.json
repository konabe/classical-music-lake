    "db:reset": "npm run db:setup && npm run db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1002.0",
    "@aws-sdk/lib-dynamodb": "^3.1003.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
