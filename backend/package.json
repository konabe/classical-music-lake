{
  "name": "classical-music-lake-backend",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:setup": "node scripts/setup-test-db.mjs",
    "db:seed": "node scripts/seed-test-db.mjs",
    "db:reset": "npm run db:setup && npm run db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1022.0",
    "@aws-sdk/client-dynamodb": "^3.1022.0",
    "@aws-sdk/lib-dynamodb": "^3.1022.0",
    "@middy/core": "^7.2.1",
    "@middy/http-cors": "^7.2.1",
    "@middy/http-error-handler": "^7.2.1",
    "@middy/http-json-body-parser": "^7.2.1",
    "@middy/http-response-serializer": "^7.2.1",
    "http-errors": "^2.0.1",
    "http-status-codes": "^2.3.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "fast-xml-parser": "5.5.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/http-errors": "^2.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "fast-check": "^4.6.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2"
  }
}
